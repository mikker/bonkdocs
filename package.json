{
  "name": "bonk-docs",
  "productName": "Bonk Docs",
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"vite --config renderer/vite.config.js --port 5173 --strictPort\" \"wait-on tcp:5173 && PEAR_DEV_SERVER_URL=http://localhost:5173 electron . --no-updates\"",
    "start": "npm run build && electron-forge start -- --no-updates",
    "build": "vite build --config renderer/vite.config.js",
    "package": "npm run build && electron-forge package",
    "make": "npm run build && electron-forge make",
    "test": "brittle test/*.test.js",
    "sim:typing": "node scripts/typing-sim.js",
    "schema:build": "node schema.js",
    "lint": "prettier --check . && lunte .",
    "format": "prettier --write .",
    "postinstall": "patch-package"
  },
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "fs/promises": {
      "bare": "bare-fs/promises",
      "default": "fs/promises"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "events": {
      "bare": "bare-events",
      "default": "events"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    },
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "node:crypto": {
      "bare": "bare-crypto",
      "default": "node:crypto"
    },
    "url": {
      "bare": "bare-url",
      "default": "url"
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/extension-collaboration": "^3.15.3",
    "@tiptap/extension-collaboration-cursor": "^3.0.0",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@tiptap/y-tiptap": "^3.0.1",
    "autobonk": "github:mikker/autobonk",
    "autobonk-yjs": "file:../autobonk-yjs",
    "bare-crypto": "^1.13.0",
    "bare-fs": "^4.5.2",
    "bare-os": "^3.6.2",
    "bare-path": "^3.0.0",
    "bare-process": "^4.2.2",
    "bare-url": "^2.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hrpc": "^4.3.0",
    "lucide-react": "^0.562.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^0.4.2",
    "protomux-wakeup": "^2.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "which-runtime": "^1.3.2",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@forkprince/electron-forge-maker-appimage": "^1.0.11",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.8",
    "@vitejs/plugin-react": "^5.1.2",
    "bare-events": "^2.8.2",
    "brittle": "^3.19.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "lunte": "^1.4.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.7.4",
    "prettier-config-holepunch": "^2.0.0",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "license": "MIT"
}
