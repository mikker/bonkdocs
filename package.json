{
  "name": "bonk-docs",
  "productName": "Bonk Docs",
  "version": "1.0.2",
  "type": "module",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "desktop:dev": "concurrently -k \"vite --config renderer/vite.config.js --port 5173 --strictPort\" \"wait-on tcp:5173 && PEAR_DEV_SERVER_URL=http://localhost:5173 electron . --no-updates\"",
    "desktop:start": "npm run desktop:build && electron-forge start -- --no-updates",
    "desktop:build": "vite build --config renderer/vite.config.js",
    "desktop:package": "npm run desktop:build && electron-forge package",
    "desktop:make": "npm run desktop:build && electron-forge make",
    "mobile:install": "cd mobile && npm install",
    "mobile:bundle:web-editor": "node scripts/build-mobile-editor-bundle.js",
    "mobile:bundle:bare": "npm run mobile:bundle:web-editor && cd mobile && npm run bundle:bare",
    "mobile:ios": "npm run mobile:bundle:web-editor && cd mobile && npm run ios",
    "test": "brittle test/*.test.js",
    "sim:typing": "node scripts/typing-sim.js",
    "schema:build": "node schema.js",
    "lint": "prettier --check . && lunte .",
    "format": "prettier --write .",
    "postinstall": "patch-package"
  },
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "fs/promises": {
      "bare": "bare-fs/promises",
      "default": "fs/promises"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "events": {
      "bare": "bare-events",
      "default": "events"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    },
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "node:crypto": {
      "bare": "bare-crypto",
      "default": "node:crypto"
    },
    "url": {
      "bare": "bare-url",
      "default": "url"
    },
    "pear-runtime": {
      "ios": "pear-mobile",
      "android": "pear-mobile",
      "simulator": "pear-mobile",
      "default": "pear-runtime"
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/extension-collaboration": "^3.20.4",
    "@tiptap/extension-collaboration-cursor": "^3.0.0",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/y-tiptap": "^3.0.2",
    "autobonk": "github:mikker/autobonk",
    "autobonk-yjs": "file:../autobonk-yjs/autobonk-yjs-0.1.0.tgz",
    "bare-console": "^6.1.0",
    "bare-crypto": "^1.13.4",
    "bare-fs": "^4.5.5",
    "bare-os": "^3.8.0",
    "bare-path": "^3.0.0",
    "bare-process": "^4.3.0",
    "bare-storage": "^1.1.0",
    "bare-system-logger": "^1.0.3",
    "bare-url": "^2.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fs": "npm:bare-fs@^4.5.5",
    "hrpc": "^4.3.0",
    "lucide-react": "^0.577.0",
    "paparam": "^1.10.1",
    "pear-mobile": "^4.2.0",
    "pear-runtime": "^1.1.0",
    "protomux-wakeup": "^2.9.0",
    "ready-resource": "^1.2.0",
    "sonner": "^2.0.7",
    "streamx": "^2.25.0",
    "tailwind-merge": "^3.5.0",
    "which-runtime": "^1.3.2",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@forkprince/electron-forge-maker-appimage": "^1.0.11",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5",
    "bare-events": "^2.8.2",
    "brittle": "^3.19.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-forge-plugin-prune-prebuilds": "^1.0.1",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "lunte": "^1.6.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7",
    "wait-on": "^9.0.4"
  },
  "license": "MIT",
  "upgrade": "pear://o7ge9tiyb5bh78zmsxcaxffd4wbydzznt4rodxp17keqsnqrxfdo"
}
