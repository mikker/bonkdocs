{
  "name": "bonk-docs",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "pear": {
    "gui": {
      "main": "renderer/dist/index.html",
      "width": 1080,
      "height": 900,
      "icon": "icon.png",
      "minWidth": 400,
      "minHeight": 300
    },
    "name": "bonk-docs",
    "pre": "pear-electron/pre",
    "stage": {
      "ignore": [
        ".lunterc",
        ".lunteignore",
        ".git",
        ".github",
        ".gitignore",
        ".prettierignore",
        ".prettierrc.json",
        "AGENTS.md",
        "README.md",
        "components.json",
        "docs",
        "node_modules/.package-lock.json",
        "node_modules/*/*.md",
        "node_modules/*/*/*.md",
        "node_modules/*/LICENSE",
        "node_modules/*/*/LICENSE",
        "node_modules/*/CHANGELOG",
        "node_modules/*/*/CHANGELOG",
        "node_modules/*/test",
        "node_modules/*/*/test",
        "package-lock.json",
        "renderer/src/**/*",
        "scripts",
        "test"
      ],
      "prefetch": [
        "assets"
      ]
    }
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:*\"",
    "dev:vite": "vite build --config renderer/vite.config.js --watch --mode development",
    "dev:pear": "pear run -d .",
    "build": "vite build --config renderer/vite.config.js",
    "test": "brittle test/*.test.js",
    "sim:typing": "node scripts/typing-sim.js",
    "schema:build": "node schema.js",
    "lint": "prettier --check . && lunte .",
    "format": "prettier --write .",
    "postinstall": "patch-package",
    "stage:dev": "npm run build && pear stage dev"
  },
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "fs/promises": {
      "bare": "bare-fs/promises",
      "default": "fs/promises"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    },
    "events": {
      "bare": "bare-events",
      "default": "events"
    },
    "process": {
      "bare": "bare-process",
      "default": "process"
    },
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    },
    "node:crypto": {
      "bare": "bare-crypto",
      "default": "node:crypto"
    },
    "url": {
      "bare": "bare-url",
      "default": "url"
    }
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@tiptap/extension-collaboration": "^3.15.3",
    "@tiptap/extension-collaboration-cursor": "^3.0.0",
    "@tiptap/y-tiptap": "^3.0.1",
    "autobonk": "github:mikker/autobonk",
    "bare-crypto": "^1.13.0",
    "bare-fs": "^4.5.2",
    "bare-os": "^3.6.2",
    "bare-path": "^3.0.0",
    "bare-process": "^4.2.2",
    "bare-url": "^2.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framed-stream": "^1.0.1",
    "hrpc": "^4.3.0",
    "lucide-react": "^0.562.0",
    "pear-bridge": "^1.2.4",
    "pear-electron": "^1.7.26",
    "pear-messages": "^1.0.5",
    "pear-pipe": "^1.0.6",
    "pear-run": "^2.0.0",
    "pear-updates": "^1.1.0",
    "protomux-wakeup": "^2.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zustand": "^5.0.10",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.8",
    "@vitejs/plugin-react": "^5.1.2",
    "bare-events": "^2.8.2",
    "brittle": "^3.19.1",
    "concurrently": "^9.2.1",
    "lunte": "^1.4.0",
    "pear-interface": "^1.1.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.7.4",
    "prettier-config-holepunch": "^2.0.0",
    "prettier-config-standard": "^7.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1"
  },
  "license": "MIT"
}
