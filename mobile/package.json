{
  "name": "bonkdocs-mobile",
  "productName": "Bonk Docs",
  "private": true,
  "version": "0.1.0",
  "upgrade": "pear://o7ge9tiyb5bh78zmsxcaxffd4wbydzznt4rodxp17keqsnqrxfdo",
  "main": "index.ts",
  "scripts": {
    "bundle:bare": "npx bare-pack --host ios-arm64 --host ios-arm64-simulator --host ios-x64-simulator --linked --out ./src/worker.bundle.js ./pearend/worker.js",
    "bundle:react-native": "npx react-native bundle --platform ios --dev false --entry-file index.ts --bundle-output ota/ios/Bonk\\ Docs/app.bundle --assets-dest ota/ios/Bonk\\ Docs && npx react-native bundle --platform android --dev false --entry-file index.ts --bundle-output ota/android/Bonk\\ Docs/app.bundle --assets-dest ota/android/Bonk\\ Docs",
    "build": "npx pear-build --ios-arm64 ./ota/ios/Bonk\\ Docs --ios-arm64-simulator ./ota/ios/Bonk\\ Docs --ios-x64-simulator ./ota/ios/Bonk\\ Docs --android-arm64 ./ota/android/Bonk\\ Docs --package ./package.json --target dist",
    "update": "npm run bundle:bare && npm run bundle:react-native && npm run build",
    "prebuild": "npx expo prebuild --platform ios",
    "preios": "npm run bundle:bare",
    "ios": "expo run:ios",
    "lint": "lunte",
    "format": "prettier . --write",
    "test": "prettier . --check && lunte",
    "android": "expo run:android"
  },
  "dependencies": {
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "bare-console": "^6.1.0",
    "bare-crypto": "^1.13.4",
    "bare-system-logger": "^1.0.3",
    "expo": "~54.0.33",
    "expo-file-system": "~19.0.0",
    "expo-status-bar": "~3.0.9",
    "graceful-goodbye": "^1.3.3",
    "pear-build": "^1.1.0",
    "pear-mobile": "^4.2.0",
    "pear-runtime-react-native": "^2.0.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-bare-kit": "^0.12.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.84.0",
    "@types/react": "~19.1.0",
    "bare-pack": "^2.0.0",
    "lunte": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "typescript": "~5.9.2"
  }
}
